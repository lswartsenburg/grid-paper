{
  "name": "grid-paper-monorepo",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "dev": "pnpm --filter @grid-paper/web dev",
    "build": "pnpm --filter @grid-paper/web build",
    "lint": "eslint",
    "format": "prettier --write .",
    "test": "pnpm --filter @grid-paper/ui test",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "commit": "cz",
    "postinstall": "git config --local core.editor cat"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4",
    "typescript": "^5"
  }
}
